<?xml version="1.0"?>
<!--
/**
 * Dependency Injection Configuration
 */
-->
<config xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:noNamespaceSchemaLocation="urn:magento:framework:ObjectManager/etc/config.xsd">

    <!-- Config Interface -->
    <preference for="ArtLounge\BentoCore\Api\ConfigInterface"
                type="ArtLounge\BentoCore\Model\Config"/>

    <!-- Bento Client Interface -->
    <preference for="ArtLounge\BentoCore\Api\BentoClientInterface"
                type="ArtLounge\BentoCore\Model\BentoClient"/>

    <!-- Virtual Type for Bento Logger -->
    <virtualType name="ArtLoungeBentoLogger" type="Magento\Framework\Logger\Monolog">
        <arguments>
            <argument name="name" xsi:type="string">bento</argument>
            <argument name="handlers" xsi:type="array">
                <item name="system" xsi:type="object">ArtLoungeBentoLogHandler</item>
            </argument>
        </arguments>
    </virtualType>

    <virtualType name="ArtLoungeBentoLogHandler" type="Magento\Framework\Logger\Handler\Base">
        <arguments>
            <argument name="fileName" xsi:type="string">/var/log/bento.log</argument>
        </arguments>
    </virtualType>

    <!-- Inject custom logger into Config -->
    <type name="ArtLounge\BentoCore\Model\Config">
        <arguments>
            <argument name="logger" xsi:type="object">ArtLoungeBentoLogger</argument>
        </arguments>
    </type>

    <!-- Inject custom logger into BentoClient -->
    <type name="ArtLounge\BentoCore\Model\BentoClient">
        <arguments>
            <argument name="logger" xsi:type="object">ArtLoungeBentoLogger</argument>
        </arguments>
    </type>

</config>
