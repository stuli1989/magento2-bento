<?xml version="1.0"?>
<!--
/**
 * Checkout Success Page Layout
 *
 * Adds purchase tracking as client-side fallback for server-side async events.
 * Uses same dedupe key (order increment_id) so Bento will deduplicate
 * if both client-side and server-side events are received.
 */
-->
<page xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
      xsi:noNamespaceSchemaLocation="urn:magento:framework:View/Layout/etc/page_configuration.xsd">
    <body>
        <referenceContainer name="before.body.end">
            <block class="Magento\Framework\View\Element\Template"
                   name="artlounge.bento.purchase.tracking"
                   template="ArtLounge_BentoTracking::purchase_tracking.phtml"
                   after="artlounge.bento.tracking.script">
                <arguments>
                    <argument name="view_model" xsi:type="object">ArtLounge\BentoTracking\ViewModel\TrackingData</argument>
                </arguments>
            </block>
        </referenceContainer>
    </body>
</page>
