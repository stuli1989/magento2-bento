<?php
/**
 * Checkout Identification Template
 *
 * Identifies guest users when they enter their email at checkout.
 * Event tracking for $checkoutStarted is now handled server-side
 * via the bento.checkout.started async event.
 *
 * @var \Magento\Framework\View\Element\Template $block
 * @var \ArtLounge\BentoTracking\ViewModel\TrackingData $viewModel
 */

$viewModel = $block->getData('view_model');

if (!$viewModel->isEnabled()) {
    return;
}
?>
<?php ob_start(); ?>
require(['Magento_Customer/js/customer-data'], function(customerData) {
    'use strict';

    if (window._bentoCheckoutIdentifyDone) return;
    window._bentoCheckoutIdentifyDone = true;

    var cart = customerData.get('cart');
    cart.subscribe(function(cartData) {
        if (cartData && cartData.customer_email && typeof bento !== 'undefined') {
            bento.identify(cartData.customer_email);
        }
    });
});
<?php $identifyScript = trim((string)ob_get_clean()); ?>
<?= /* @noEscape */ $secureRenderer->renderTag('script', [], $identifyScript, false) ?>
