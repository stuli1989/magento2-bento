<?xml version="1.0"?>
<!--
/**
 * Default Layout - Inject Bento tracking script on all pages
 */
-->
<page xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
      xsi:noNamespaceSchemaLocation="urn:magento:framework:View/Layout/etc/page_configuration.xsd">
    <body>
        <referenceContainer name="before.body.end">
            <block class="Magento\Framework\View\Element\Template"
                   name="artlounge.bento.tracking.script"
                   template="ArtLounge_BentoTracking::bento_script.phtml">
                <arguments>
                    <argument name="view_model" xsi:type="object">ArtLounge\BentoTracking\ViewModel\TrackingData</argument>
                </arguments>
            </block>
        </referenceContainer>
    </body>
</page>
