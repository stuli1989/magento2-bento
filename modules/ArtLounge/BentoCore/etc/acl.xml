<?xml version="1.0"?>
<!--
/**
 * Access Control List Configuration
 */
-->
<config xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:noNamespaceSchemaLocation="urn:magento:framework:Acl/etc/acl.xsd">
    <acl>
        <resources>
            <resource id="Magento_Backend::admin">
                <resource id="Magento_Backend::stores">
                    <resource id="Magento_Backend::stores_settings">
                        <resource id="Magento_Config::config">
                            <resource id="ArtLounge_BentoCore::config" title="ArtLounge Bento Integration" sortOrder="100">
                                <resource id="ArtLounge_BentoCore::config_general" title="General Settings" sortOrder="10"/>
                                <resource id="ArtLounge_BentoCore::config_orders" title="Order Events" sortOrder="20"/>
                                <resource id="ArtLounge_BentoCore::config_customers" title="Customer Events" sortOrder="30"/>
                                <resource id="ArtLounge_BentoCore::config_newsletter" title="Newsletter Events" sortOrder="40"/>
                                <resource id="ArtLounge_BentoCore::config_abandoned_cart" title="Abandoned Cart" sortOrder="50"/>
                                <resource id="ArtLounge_BentoCore::config_tracking" title="Client-Side Tracking" sortOrder="60"/>
                                <resource id="ArtLounge_BentoCore::config_advanced" title="Advanced Settings" sortOrder="70"/>
                            </resource>
                        </resource>
                    </resource>
                </resource>
            </resource>
        </resources>
    </acl>
</config>
