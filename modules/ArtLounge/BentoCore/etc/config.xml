<?xml version="1.0"?>
<!--
/**
 * Default Configuration Values
 */
-->
<config xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:noNamespaceSchemaLocation="urn:magento:module:Magento_Store:etc/config.xsd">
    <default>
        <artlounge_bento>
            <!-- General Settings -->
            <general>
                <enabled>0</enabled>
                <site_uuid></site_uuid>
                <publishable_key></publishable_key>
                <secret_key backend_model="Magento\Config\Model\Config\Backend\Encrypted"/>
                <source>artlounge</source>
                <debug>0</debug>
            </general>

            <!-- Order Events -->
            <orders>
                <enabled>1</enabled>
                <track_placed>1</track_placed>
                <track_shipped>1</track_shipped>
                <track_cancelled>1</track_cancelled>
                <track_refunded>1</track_refunded>
                <include_tax>1</include_tax>
                <currency_multiplier>100</currency_multiplier>
                <include_images>1</include_images>
                <include_categories>1</include_categories>
            </orders>

            <!-- Customer Events -->
            <customers>
                <enabled>1</enabled>
                <track_created>1</track_created>
                <track_updated>0</track_updated>
                <default_tags>lead,mql</default_tags>
                <include_address>1</include_address>
            </customers>

            <!-- Newsletter Events -->
            <newsletter>
                <enabled>1</enabled>
                <track_subscribe>1</track_subscribe>
                <track_unsubscribe>1</track_unsubscribe>
                <subscribe_tags>newsletter</subscribe_tags>
            </newsletter>

            <!-- Abandoned Cart -->
            <abandoned_cart>
                <enabled>1</enabled>
                <delay_minutes>60</delay_minutes>
                <min_value>500</min_value>
                <require_email>1</require_email>
                <exclude_groups></exclude_groups>
                <processing_method>cron</processing_method>
                <include_recovery_url>1</include_recovery_url>
                <prevent_duplicates>1</prevent_duplicates>
                <duplicate_window>24</duplicate_window>
            </abandoned_cart>

            <!-- Client-Side Tracking -->
            <tracking>
                <enabled>1</enabled>
                <track_views>1</track_views>
                <track_add_to_cart>1</track_add_to_cart>
                <track_checkout>1</track_checkout>
                <add_to_cart_selector>#product-addtocart-button, .add_cart_btn.addToCart</add_to_cart_selector>
                <include_brand>1</include_brand>
                <brand_attribute>manufacturer</brand_attribute>
            </tracking>

            <!-- Advanced Settings -->
            <advanced>
                <max_retries>5</max_retries>
                <log_retention>30</log_retention>
                <elasticsearch>1</elasticsearch>
                <timeout>30</timeout>
            </advanced>
        </artlounge_bento>
    </default>
</config>
