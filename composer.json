{
  "name": "artlounge/bento-integration",
  "type": "library",
  "require": {
    "php": "^8.1"
  },
  "require-dev": {
    "phpunit/phpunit": "^9.5",
    "mockery/mockery": "^1.6",
    "symfony/console": "^5.4 || ^6.0 || ^7.0"
  },
  "autoload": {
    "psr-4": {
      "ArtLounge\\BentoCore\\": "modules/ArtLounge/BentoCore/",
      "ArtLounge\\BentoEvents\\": "modules/ArtLounge/BentoEvents/",
      "ArtLounge\\BentoTracking\\": "modules/ArtLounge/BentoTracking/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "Tests\\": "tests/",
      "Aligent\\AsyncEvents\\": "tests/Stubs/Aligent/AsyncEvents/",
      "Magento\\": "tests/Stubs/Magento/",
      "Ramsey\\Uuid\\": "tests/Stubs/Ramsey/Uuid/",
      "Psr\\Log\\": "tests/Stubs/Psr/Log/"
    }
  },
  "minimum-stability": "stable",
  "prefer-stable": true
}
